# URL pública da API — deixe vazio para usar o proxy `/api` (mesmo origin)
NEXT_PUBLIC_API_URL=

# Destino do rewrite `/api/*` (Kestrel)
BACKEND_URL=http://127.0.0.1:5280

# URL do próprio site (OAuth redirect, links de convite)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth — Client ID Web (público no browser)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

