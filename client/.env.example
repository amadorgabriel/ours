# URL pública da API (.NET)
NEXT_PUBLIC_API_URL=http://localhost:5280

# URL do próprio site (OAuth redirect, links de convite)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google OAuth (client ID é público no browser; segredo só no servidor se usar BFF)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Opcional: usado apenas no servidor (nunca prefixo NEXT_PUBLIC_)
# GOOGLE_CLIENT_SECRET=

