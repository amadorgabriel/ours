{
  "info": {
    "name": "Project Ours — Auth",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Fluxo de auth contra a API direta (Kestrel). Variável `baseUrl` padrão: http://localhost:5280. No browser, use o proxy Next (`/api/...`) no mesmo origin."
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5280" },
    { "key": "antiforgeryToken", "value": "" },
    { "key": "googleIdToken", "value": "" },
    { "key": "familyId", "value": "" }
  ],
  "item": [
    {
      "name": "1 — GET antiforgery",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/auth/antiforgery"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const j = pm.response.json();",
              "pm.collectionVariables.set('antiforgeryToken', j.requestToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "2 — POST Google login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "RequestVerificationToken", "value": "{{antiforgeryToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"idToken\": \"{{googleIdToken}}\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/google"
      }
    },
    {
      "name": "3 — GET health",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/health"
      }
    },
    {
      "name": "4 — GET me active-family",
      "request": {
        "method": "GET",
        "header": [{ "key": "X-Family-Id", "value": "{{familyId}}" }],
        "url": "{{baseUrl}}/api/me/active-family"
      }
    },
    {
      "name": "5 — POST logout",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "RequestVerificationToken", "value": "{{antiforgeryToken}}" }
        ],
        "body": { "mode": "raw", "raw": "" },
        "url": "{{baseUrl}}/api/auth/logout"
      }
    },
    {
      "name": "6 — POST refresh (501)",
      "request": {
        "method": "POST",
        "url": "{{baseUrl}}/api/auth/refresh"
      }
    }
  ]
}
