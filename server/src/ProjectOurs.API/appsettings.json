{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=projectours;Username=postgres;Password=your_password_here"
  },
  "JwtSettings": {
    "Secret": "your-super-secret-key-with-at-least-32-characters!",
    "Issuer": "project-ours-api",
    "Audience": "project-ours-app",
    "ExpirationHours": 24
  },
  "GoogleAuth": {
    "ClientId": "your-google-client-id.apps.googleusercontent.com"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000"
    ]
  }
}
